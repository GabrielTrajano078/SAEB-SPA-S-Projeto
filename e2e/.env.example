# Copie para e2e/.env e ajuste (e2e/.env não é versionado).

# URL da SPA. Deve coincidir com o webServer do Playwright (Vite em 127.0.0.1:5173).
E2E_BASE_URL=http://127.0.0.1:5173

# URL direta da API (opcional; usada por diagnose e futuros testes de API).
# E2E_API_URL=http://127.0.0.1:3001

# Nome do projeto Docker Compose (evita colisão com outros stacks).
E2E_PROJECT_NAME=saeb-spas-e2e

# Porta do MongoDB no host (padrão 27018 para não conflitar com 27017 local).
E2E_MONGO_PORT=27018

# Se 1, não falha o global-setup quando /health não responde (útil sem backend).
E2E_SKIP_API_SMOKE=0

# Se 1, o Playwright não tenta subir o Vite (você já tem o webServer rodando).
E2E_SKIP_WEB_SERVER=0
